{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["XcodeBuildMCP"],
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(swift *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./fastlane/Appfile)",
      "Read(./fastlane/Matchfile)",
      "Read(./fastlane/.env*)"
    ]
  }
}
